font-family = Menlo
font-size = 12
font-synthetic-style = false
#adjust-cell-width = -5%
adjust-cell-height = 30%
font-thicken = true

window-padding-x = 11
window-padding-y = 0
#window-step-resize = true
window-width = 80
window-height = 24
window-vsync = true

macos-titlebar-style = transparent
#macos-window-buttons = hidden
macos-option-as-alt = true

quit-after-last-window-closed = true
shell-integration-features = ssh-env
bell-features = system
mouse-hide-while-typing = true
cursor-opacity = 1.0


theme = light:patched-modus-operandi, dark:patched-modus-vivendi

keybind = shift+escape=text:~
keybind = option+delete=esc:d
keybind = command+delete=text:\x0b
keybind = command+up=jump_to_prompt:-2
keybind = command+down=jump_to_prompt:+2
keybind = command+enter=unbind
keybind = command+ctrl+right=unbind
keybind = command+ctrl+left=unbind
keybind = command+1=unbind
keybind = command+2=unbind
keybind = command+3=unbind
keybind = command+4=unbind
keybind = command+5=unbind
keybind = command+6=unbind
keybind = command+7=unbind
keybind = command+8=unbind
keybind = command+9=unbind
