font-family = Menlo
font-size = 12
font-synthetic-style = false
#adjust-cell-width = -5%
adjust-cell-height = 30%
font-thicken = true

window-padding-x = 11
window-padding-y = 0
#window-step-resize = true
window-width = 80
window-height = 24
window-vsync = true

macos-titlebar-style = transparent
#macos-window-buttons = hidden
macos-option-as-alt = true

quit-after-last-window-closed = true
shell-integration-features = ssh-env
bell-features = system
mouse-hide-while-typing = true
cursor-opacity = 1.0

theme = light:modus-operandi, dark:modus-vivendi

keybind = super+up=jump_to_prompt:-2
keybind = super+down=jump_to_prompt:+2
keybind = super+enter=unbind
keybind = super+ctrl+right=unbind
keybind = super+ctrl+left=unbind
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind
keybind = super+9=unbind
