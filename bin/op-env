#!/usr/bin/env bash
# shellcheck disable=SC2016

main() {
    # Disable shell tracing to prevent secrets from being exposed in logs if set -x is active
    set +x

    ACCOUNT="my.1password.eu"
    SECRETS_FILE="$HOME/.op_secrets"

    # Translates the list of names into op path mappings
    generate_mappings() {
        while read -r name || [[ -n "$name" ]]; do
            [[ -z "$name" || "$name" == "#"* ]] && continue
            echo "${name}=\"op://Private/${name}/credential\""
        done < "$SECRETS_FILE"
    }

    # Extracts the secrets securely from 1Password.
    #
    # Note: We use `eval "$(get_secrets)"` below rather than `op run` to
    # fix passing signals like SIGWINCH (terminal resize) to the final
    # process. `op run` wraps the command and fails to forward window
    # change signals, breaking terminal UIs (like `opencode`). By
    # `eval`'ing the secrets into this script's memory and then using
    # `exec`, the final application replaces this process and receives
    # signals directly.
    #
    # TRADE-OFFS:
    # - Security: Secrets pass through a plaintext pipe/memory for a brief moment.
    # - Debugging: 'set -x' is disabled here, but one must still be cautious
    #   not to log the output of this script in plaintext.
    get_secrets() {
        op run --no-masking --account "$ACCOUNT" --env-file <(generate_mappings) -- \
            "$SHELL" -c 'for n in $(grep -v "^#" ~/.op_secrets); do echo "export $n=\"${!n}\""; done'
    }

    if [[ $# -eq 0 ]] ; then
        get_secrets
    else
        # exec op run --account "$ACCOUNT" --env-file <(generate_mappings) -- "$@"
        eval "$(get_secrets)" && exec "$@"
    fi
}

main "$@"
unset main
